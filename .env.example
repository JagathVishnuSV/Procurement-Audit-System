# ─────────────────────────────────────────────────────────────────────────────
# Procurement Audit System – Environment Configuration
# Copy this file to `.env` and fill in your values.
# NEVER commit `.env` to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="Procurement Audit System"
APP_ENV=development        # development | staging | production
DEBUG=false
LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR | CRITICAL

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=procurement_user
POSTGRES_PASSWORD=procurement_pass
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=procurement_audit

# ── Redis (Feature Store / Cache) ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=            # Leave blank if no auth

# ── Redpanda / Kafka ───────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:19092

# Topic names (defaults match architecture doc)
KAFKA_TOPIC_RAW_TRANSACTIONS=raw_transactions
KAFKA_TOPIC_ENRICHED_TRANSACTIONS=enriched_transactions
KAFKA_TOPIC_ANOMALIES=anomalies_topic
KAFKA_TOPIC_TRIAGE=triage_topic
KAFKA_TOPIC_DEEP_AUDIT=deep_audit_topic

# ── Machine Learning ───────────────────────────────────────────────────────────
ML_ANOMALY_THRESHOLD=0.1   # Isolation Forest decision threshold
ML_MODEL_PATH=models/isolation_forest.joblib
ML_CONTAMINATION=0.05      # Expected fraction of anomalies (5%)

# ── LLM APIs (Sprint 4) ────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.0
GROQ_TOP_P=0.85
GROQ_MAX_TOKENS=120
GROQ_MAX_INPUT_CHARS=3500
GROQ_TIMEOUT_SECONDS=20
GROQ_MAX_RETRIES=3
GROQ_RATE_LIMIT_PER_MINUTE=12
GROQ_DAILY_QUOTA=400
GROQ_SOFT_ESCALATION_ML_SCORE=0.60
GROQ_HARD_ESCALATION_ML_SCORE=0.80
GROQ_MIN_SIGNAL_HITS_FOR_SOFT_ESCALATION=2

GEMINI_MODEL=gemini-1.5-flash
GEMINI_TEMPERATURE=0.0
GEMINI_TOP_P=0.8
GEMINI_MAX_OUTPUT_TOKENS=220
GEMINI_MAX_CLAUSES=2
GEMINI_MAX_CLAUSE_CHARS=850
GEMINI_MAX_INPUT_CHARS=5000
GEMINI_TIMEOUT_SECONDS=30
GEMINI_MAX_RETRIES=3
GEMINI_RATE_LIMIT_PER_MINUTE=6
GEMINI_DAILY_QUOTA=200

# ── Data Ingestion ─────────────────────────────────────────────────────────────
USASPENDING_BASE_URL=https://api.usaspending.gov
USASPENDING_PULL_INTERVAL_SECONDS=300   # Poll every 5 minutes
USASPENDING_MAX_RECORDS_PER_PULL=100
CPPP_BASE_URL=https://eprocure.gov.in/eprocure/app?page=FrontEndLatestActiveTenders&service=page
CPPP_PULL_INTERVAL_SECONDS=600
CPPP_MAX_RECORDS_PER_PULL=100
OCDS_BASE_URL=https://data.open-contracting.org/en/publication/128/download?name=2026.jsonl.gz
OCDS_PULL_INTERVAL_SECONDS=600
OCDS_MAX_RECORDS_PER_PULL=100
INGESTION_POLL_INTERVAL_SECONDS=300
INGESTION_LOOP_ENABLED=true
INGESTION_LIMIT_PER_SOURCE=100

KAFKA_CONSUMER_ENABLED=true
KAFKA_CONSUMER_GROUP=procurement_ingestion_workers
KAFKA_CONSUMER_AUTO_OFFSET_RESET=latest
KAFKA_CONSUMER_TRIGGER_ORCHESTRATION=true

# ── Automated Orchestration (Coverage Uplift) ─────────────────────────────────
ORCH_ENABLED=true
ORCH_INTERVAL_SECONDS=120
ORCH_BATCH_SIZE=200
ORCH_CASE_POLICY=ALL_SCORED
ORCH_RUN_LLM=true
ORCH_MAX_LLM_PER_RUN=200
ORCH_LLM_MIN_SCORE=0.0

# ── Vector Store (Sprint 3) ────────────────────────────────────────────────────
FAISS_INDEX_PATH=data/faiss_index
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── CORS Origins (Frontend) ────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
